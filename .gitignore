# ── NEVER COMMIT THESE ──────────────────────────────
# Secrets: bank tokens, API keys, anything sensitive
.env
.env.*
*.secret
.simplefin

# Your actual financial data — stays on YOUR machine only
data/
*.sqlite
*.sqlite3
*.db
transactions*.json
accounts*.json
# local backups of your data — stay on your machine
backups/
# ────────────────────────────────────────────────────

# macOS noise
.DS_Store
*.log

# Python
__pycache__/
*.pyc

# Toggl API token (credential) — never commit
.toggl

# PostHog Personal API key (read access) — founder only, never commit
.posthog

# Founder lock — presence of this file marks THIS machine as King Cozy.
# Never commit: it's what keeps founder-only surfaces personal to you.
.founder

# Brand/design references — private, local only
BRAND.md

# Cloud architecture plan — private security/strategy doc
CLOUD-PLAN.md

# WebDAV backup target (url/user/pass) — local only, never commit
.webdav
